    "Connection timed out. The server might be down or the address is incorrect." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انتهت مهلة الاتصال. قد يكون الخادم معطلاً أو العنوان غير صحيح."
          }
        },
        "de" : {
          "stringUnit" : {
