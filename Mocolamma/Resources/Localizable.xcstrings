    "TLS error occurred. Could not establish a secure connection." : {
      "comment" : "TLS接続エラー時のメッセージ。",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدث خطأ في TLS. تعذر إنشاء اتصال آمن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TLS-Fehler aufgetreten. Es konnte keine sichere Verbindung hergestellt werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TLS error occurred. Could not establish a secure connection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ocurrió un error TLS. No se pudo establecer una conexión segura."
          }
        },
        "fr" : {
