    "Sets how far back for the model to look back to prevent repetition." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدد مدى رجوع النموذج للخلف لمنع التكرار."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt fest, wie weit das Modell zurückblickt, um Wiederholungen zu vermeiden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sets how far back for the model to look back to prevent repetition."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establece qué tan atrás debe mirar el modelo para evitar la repetición."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définit la distance à laquelle le modèle doit regarder en arrière pour éviter les répétitions."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルの繰り返し出力を防止するために遡るトークン数を指定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "반복을 방지하기 위해 모델이 되돌아볼 범위를 설정합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Определяет, как далеко назад должен смотреть модель, чтобы предотвратить повторения."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
