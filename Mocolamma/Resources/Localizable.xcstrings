        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я буду дуже радий, якщо ви поставите зірку репозиторію!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您能为仓库点亮星标，我将不胜感激！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您能為倉庫點亮星標，我將不勝感激！"
