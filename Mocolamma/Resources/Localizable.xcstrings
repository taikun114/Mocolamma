        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I would be so glad if you could give a star to the repository!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Me alegraría mucho si pudieras darle una estrella al repositorio!"
