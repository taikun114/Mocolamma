    "You can support me at Buy Me a Coffee from the price of a cup of green tea." : {
      "comment" : "Buy Me a Coffeeを使って開発者を緑茶1杯分の価格からサポートすることができることを紹介するテキスト。",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك دعمي على Buy Me a Coffee بسعر كوب من الشاي الأخضر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können mich bei Buy Me a Coffee ab dem Preis einer Tasse grünen Tees unterstützen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can support me at Buy Me a Coffee from the price of a cup of green tea."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes apoyarme en Buy Me a Coffee desde el precio de una taza de té verde."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez me soutenir sur Buy Me a Coffee à partir du prix d'une tasse de thé vert."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buy Me a Coffeeで、緑茶一杯分の金額からサポートしていただけます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buy Me a Coffee에서 녹차 한 잔 가격으로 개발자를 후원하실 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
