        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ストリームレスポンスをオフにする場合、設定からAPIタイムアウトを無制限にすることをおすすめします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "스트림 응답을 끄는 경우, 설정에서 API 타임아웃을 무제한으로 설정하는 것을 권장합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При отключении потоковых ответов рекомендуется установить тайм-аут API на «Без ограничений» в настройках."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При відключенні потокових відповідей рекомендується встановити тайм-аут API на «Без обмежень» у налаштуваннях."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您关闭流式响应，建议在设置中将 API 超时时间设置为“无限制”。"
