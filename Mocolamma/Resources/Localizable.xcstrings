    "Specifies the maximum number of tokens the model can remember (reference) during a session." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدد الحد الأقصى لعدد الرموز التي يمكن للنموذج تذكرها (الرجوع إليها) خلال جلسة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt die maximale Anzahl von Token fest, die sich das Modell während einer Sitzung merken (auf die es sich beziehen) kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specifies the maximum number of tokens the model can remember (reference) during a session."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Especifica el número máximo de tokens que el modelo puede recordar (referenciar) durante una sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spécifie le nombre maximum de jetons que le modèle peut mémoriser (référencer) au cours d'une session."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルがセッション中に記憶できる（参照できる）最大トークン数を指定します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "세션 동안 모델이 기억할 수 있는(참조할 수 있는) 최대 토큰 수를 지정합니다."
