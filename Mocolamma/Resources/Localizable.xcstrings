        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Указывает максимальное количество токенов, которые модель может запомнить (использовать в качестве ссылки) во время сеанса."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вказує максимальну кількість токенів, які модель може запам'ятати (використовувати як посилання) під час сеансу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在会话期间可以记住（参考）的最大标记数量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在會話期間可以記住（參考）的最大標記數量。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在會話期間可以記住（參考）的最大標記數量。"
          }
        }
      }
    },
    "Specifies the model temperature. Increasing the temperature makes the response more creative, while decreasing it makes it more accurate." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدد درجة حرارة النموذج. زيادة درجة الحرارة تجعل الاستجابة أكثر إبداعًا، بينما تقليلها يجعلها أكثر دقة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt die Modelltemperatur fest. Eine Erhöhung der Temperatur macht die Antwort kreativer, während eine Verringerung sie genauer macht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specifies the model temperature. Increasing the temperature makes the response more creative, while decreasing it makes it more accurate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Especifica la temperatura del modelo. Aumentar la temperatura hace que la respuesta sea más creativa, mientras que disminuirla la hace más precisa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spécifie la température du modèle. L'augmentation de la température rend la réponse plus créative, tandis que sa diminution la rend plus précise."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルの温度を指定します。温度を上げると回答がより創造的になり、温度を下げるとより正確的になります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델 온도를 지정합니다. 온도를 높이면 응답이 더 창의적이 되고, 낮추면 더 정확해집니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Указывает температуру модели. Увеличение температуры делает ответ более творческим, а уменьшение — более точным."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вказує температуру моделі. Збільшення температури робить відповідь більш творчою, а зменшення — більш точною."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型温度。提高温度使响应更具创造性，降低温度使响应更准确。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型溫度。提高溫度使響應更具創造性，降低溫度使響應更準確。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型溫度。提高溫度使響應更具創造性，降低溫度使響應更準確。"
          }
        }
      }
    },
    "Specifies the number of image generation steps. Increasing the number of steps increases generation time but can improve detail." : {
      "comment" : "A description below the slider that explains its purpose.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدد عدد خطوات توليد الصورة. زيادة عدد الخطوات يزيد من وقت التوليد ولكن يمكن أن يحسن التفاصيل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gibt die Anzahl der Bilderzeugungsschritte an. Eine Erhöhung der Anzahl der Schritte verlängert die Erzeugungszeit, kann aber die Details verbessern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specifies the number of image generation steps. Increasing the number of steps increases generation time but can improve detail."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Especifica el número de pasos de generación de imágenes. Aumentar el número de pasos aumenta el tiempo de generación pero puede mejorar el detalle."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spécifie le nombre d'étapes de génération d'image. L'augmentation du nombre d'étapes augmente le temps de génération mais peut améliorer les détails."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "画像生成のステップ数を指定します。ステップ数を増やすと生成にかかる時間が長くなりますが、ディテールを向上させることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이미지 생성 단계를 지정합니다. 단계를 늘리면 생성 시간은 길어지지만 디테일은 향상될 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Указывает количество шагов генерации. Увеличение числа шагов увеличивает время генерации, но может улучшить детализацию."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вказує кількість кроків генерації. Збільшення числа кроків збільшує час генерації, але може покращити деталізацію."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定图像生成的步数。增加步数会增加生成时间，但可以提高细节。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定圖片生成的步數。增加步數會增加生成時間，但可以提高細節。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定圖片生成的步數。增加步數會增加生成時間，但可以提高細節。"
          }
        }
      }
    },
