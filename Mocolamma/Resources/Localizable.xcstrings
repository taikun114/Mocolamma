    "Specify how long the model will stay loaded into memory. Models can be unloaded at any time." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حدد المدة التي سيبقى فيها النموذج محملاً في الذاكرة. يمكن إلغاء تحميل النموذج في أي وقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legen Sie fest, wie lange das Modell im Speicher geladen bleibt. Modelle können jederzeit entladen werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specify how long the model will stay loaded into memory. Models can be unloaded at any time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Especifique cuánto tiempo permanecerá cargado el modelo en memoria. Los modelos se pueden descargar en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spécifiez la durée pendant laquelle le modèle restera chargé en mémoire. Les modèles peuvent être déchargés à tout moment."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルをサーバー上に保持する時間を指定します。モデルはいつでもアンロードできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모델이 메모리에 로드된 상태로 유지될 시간을 지정합니다. 모델은 언제든지 언로드할 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Укажите, как долго модель будет оставаться загруженной в память. Модели можно выгрузить в любое время."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вкажіть, як довго модель залишатиметься завантаженою в пам'яті. Моделі можна вивантажити в будь-який час."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在内存中保留的时间。可以随时卸载模型。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在記憶體中保留的時間。可以隨時卸載模型。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指定模型在記憶體中保留的時間。可以隨時卸載模型。"
          }
        }
      }
    },
